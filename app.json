{
  "expo": {
    "name": "ReSelecto",
    "slug": "reselecto-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Az alkalmazásnak kamerára van szüksége a szállítási fotók készítéséhez.",
        "NSPhotoLibraryUsageDescription": "Az alkalmazásnak hozzá kell férnie a fotótárhoz a képek mentéséhez."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CALL_PHONE",
        "SEND_SMS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-media-library",
      [
        "expo-image-picker",
        {
          "photosPermission": "Az alkalmazásnak hozzá kell férnie a fotótárhoz."
        }
      ]
    ]
  }
}
