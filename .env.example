# ============================================================
# ReSelecto App – Környezeti változók
# ============================================================
# Másold ezt a fájlt .env névre és töltsd ki az értékeket.
# SOHA ne commitold a .env fájlt verziókezelőbe!
# ============================================================

# --- Google Sheets API ---
# A service account JSON fájl elérési útja (vagy base64 kódolva)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEET_NAME=Szallitasok

# --- Dropbox API ---
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here
DROPBOX_ROOT_FOLDER=/Szallitas

# --- Alkalmazás beállítások ---
APP_ENV=development
